---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="RCP para Tod@s - Andes Salud">
  <main class="min-h-dvh flex flex-col px-5 py-8 max-w-md mx-auto">
    <!-- Header -->
    <div class="text-center mb-8">
      <img src={`${base}logo-icon.png`} alt="Andes Salud" class="w-20 h-20 mx-auto mb-4 rounded-2xl" />
      <h1 class="text-2xl font-extrabold text-andes-navy leading-tight">
        Reanimación<br>Cardio-Pulmonar
      </h1>
      <p class="text-andes-red font-bold text-lg mt-1">(RCP) para Tod@s</p>
      <img src={`${base}logo-andes-salud.png`} alt="Andes Salud" class="h-8 mx-auto mt-3" />
    </div>

    <!-- Menu -->
    <nav class="flex flex-col gap-4 flex-1">
      <a href={`${base}guia-rcp`} class="card flex items-center gap-4 active:scale-[0.98] transition-transform">
        <div class="w-14 h-14 rounded-2xl bg-andes-red/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-andes-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 12h6M12 9v6" stroke-linecap="round"/>
            <rect x="3" y="3" width="18" height="18" rx="4"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-andes-navy">Guía RCP Paso a Paso</h2>
          <p class="text-sm text-gray-500">6 pasos para salvar una vida</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <a href={`${base}metronomo`} class="card flex items-center gap-4 active:scale-[0.98] transition-transform">
        <div class="w-14 h-14 rounded-2xl bg-andes-navy/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-andes-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 3" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-andes-navy">Metrónomo RCP</h2>
          <p class="text-sm text-gray-500">Ritmo 100-120 compresiones/min</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <a href={`${base}guia-dea`} class="card flex items-center gap-4 active:scale-[0.98] transition-transform">
        <div class="w-14 h-14 rounded-2xl bg-amber-500/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-andes-navy">Guía Uso DEA</h2>
          <p class="text-sm text-gray-500">Desfibrilador externo automático</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <a href={`${base}simulador-dea`} class="card flex items-center gap-4 active:scale-[0.98] transition-transform border-2 border-andes-red/20">
        <div class="w-14 h-14 rounded-2xl bg-andes-red flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-andes-red">Simulador DEA</h2>
          <p class="text-sm text-gray-500">Practica con el desfibrilador</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <a href={`${base}timer`} class="card flex items-center gap-4 active:scale-[0.98] transition-transform">
        <div class="w-14 h-14 rounded-2xl bg-andes-sky/30 flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-andes-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="13" r="8"/>
            <path d="M12 9v4l2 2" stroke-linecap="round"/>
            <path d="M10 2h4M12 2v2" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-andes-navy">Timer de Práctica</h2>
          <p class="text-sm text-gray-500">Cronómetro para simulación con robot</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>

    <!-- Disclaimer -->
    <div class="mt-8 p-4 bg-andes-navy/5 rounded-2xl border border-andes-navy/10">
      <p class="text-sm text-andes-navy text-center font-medium">
        Ante cualquier duda o emergencia, consulte en nuestro Servicio de Urgencia, Andes Salud Puerto Montt.
      </p>
    </div>

    <!-- Footer -->
    <footer class="text-center mt-6 pt-6 border-t border-gray-100">
      <p class="text-xs text-gray-400">Basado en guías AHA 2025 — Solo adultos</p>
      <p class="text-xs text-gray-400 mt-1">Andes Salud — Capacitación RCP</p>
    </footer>
  </main>
</Layout>
