---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const iconos = [
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-andes-navy"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-andes-navy"><path d="m10.2 13.2l-1.05-1.05q.2-.275.275-.562T9.5 11t-.075-.587t-.275-.538L10.2 8.8q.4.475.6 1.05T11 11t-.2 1.138t-.6 1.062m2.125 2.15l-1.075-1.075q.625-.7.938-1.55T12.5 11t-.312-1.712t-.938-1.538l1.075-1.075q.85.925 1.263 2.038T14 11t-.413 2.3t-1.262 2.05M5 12q-.825 0-1.412-.587T3 10t.588-1.412T5 8t1.413.588T7 10t-.587 1.413T5 12m-4 4v-.575q0-.6.325-1.1t.9-.75q.65-.275 1.338-.425T5 13t1.438.15t1.337.425q.575.25.9.75t.325 1.1V16zm18-4q-.825 0-1.412-.587T17 10t.588-1.412T19 8t1.413.588T21 10t-.587 1.413T19 12m-4 4v-.575q0-.6.325-1.1t.9-.75q.65-.275 1.337-.425T19 13t1.437.15t1.338.425q.575.25.9.75t.325 1.1V16z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-andes-red"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-andes-navy"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-andes-red"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-500"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg>',
];

const pasos = [
  {
    titulo: 'Seguridad de la escena',
    descripcion: 'Asegura que el entorno sea seguro para ti y la persona afectada. Usa guantes si están disponibles.',
    detalle: 'Observa el entorno: tráfico, electricidad, gases. No te conviertas en otra víctima.',
  },
  {
    titulo: 'Comprobar respuesta',
    descripcion: '¿Señor/a, está bien? Toca los hombros firmemente y habla fuerte.',
    detalle: 'Estimula ambos hombros. Si no responde, pide ayuda inmediatamente.',
  },
  {
    titulo: 'Llamar al 131',
    descripcion: 'Si no responde, pide a alguien que llame al 131 y traiga un DEA si hay uno disponible.',
    detalle: 'Si estás solo, llama tú con altavoz. Activa el protocolo de emergencia.',
  },
  {
    titulo: 'Evaluar respiración',
    descripcion: 'Evalúa si la persona respira normalmente durante no más de 10 segundos.',
    detalle: 'Mira el pecho (¿sube y baja?), escucha y siente. Los jadeos (gasping) NO son respiración normal.',
  },
  {
    titulo: 'Compresiones torácicas',
    descripcion: 'Si no tiene pulso y no respira: coloca tus manos en el centro del pecho e inicia compresiones.',
    detalle: '',
  },
  {
    titulo: 'Usar el DEA',
    descripcion: 'Enciende el DEA y sigue sus instrucciones de voz. Coloca los parches según las indicaciones.',
    detalle: 'No detengas las compresiones mientras colocan los parches. Solo detente cuando el DEA lo indique.',
  },
];
---

<Layout title="Guía RCP - Paso a Paso">
  <main class="min-h-dvh px-5 py-6 max-w-md mx-auto">
    <a href={base} class="nav-back">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Volver
    </a>

    <h1 class="text-2xl font-extrabold text-andes-navy mt-2 mb-2">Guía RCP</h1>
    <p class="text-sm text-gray-500 mb-6">Adultos — 6 pasos para salvar una vida</p>

    <div class="space-y-4">
      {pasos.map((paso, i) => (
        <details class="card group" id={`paso-${i + 1}`}>
          <summary class="flex items-start gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <div class="step-number">{i + 1}</div>
            <div class="flex-1">
              <h2 class="font-bold text-andes-navy">{paso.titulo}</h2>
              <p class="text-sm text-gray-600 mt-1">{paso.descripcion}</p>
            </div>
            <span class="mt-1" set:html={iconos[i]} />
          </summary>
          <div class="mt-4 pt-4 border-t border-gray-100 ml-14">
            {paso.detalle && <p class="text-sm text-gray-700 leading-relaxed">{paso.detalle}</p>}
            {i === 4 && (
              <div class="space-y-2 mt-1">
                <div class="flex items-start gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  <p class="text-sm text-gray-700"><strong class="text-andes-navy">Frecuencia:</strong> 100–120/min (ideal 110)</p>
                </div>
                <div class="flex items-start gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  <p class="text-sm text-gray-700"><strong class="text-andes-navy">Profundidad:</strong> 5 a 6 cm — comprime fuerte</p>
                </div>
                <div class="flex items-start gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  <p class="text-sm text-gray-700"><strong class="text-andes-navy">Ubicación:</strong> centro del pecho, manos entrelazadas, brazos rectos</p>
                </div>
                <div class="flex items-start gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  <p class="text-sm text-gray-700"><strong class="text-andes-navy">Re-expansión:</strong> deja que el pecho vuelva a subir entre compresiones</p>
                </div>
                <div class="flex items-start gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  <p class="text-sm text-gray-700"><strong class="text-andes-navy">No pares:</strong> minimiza interrupciones, rota cada 2 min si es posible</p>
                </div>
              </div>
              <a href={`${base}herramientas`} class="inline-flex items-center gap-2 mt-3 text-sm font-semibold text-andes-red">
                Abrir metrónomo →
              </a>
            )}
            {i === 5 && (
              <a href={`${base}simulador-dea`} class="inline-flex items-center gap-2 mt-3 text-sm font-semibold text-andes-red">
                Practicar con simulador DEA →
              </a>
            )}
          </div>
        </details>
      ))}
    </div>

    <div class="mt-8 p-4 bg-andes-red/5 rounded-2xl border border-andes-red/10">
      <p class="text-sm font-bold text-andes-red text-center">
        ⚡ ACTUAR RÁPIDO PUEDE MARCAR LA DIFERENCIA
      </p>
      <p class="text-xs text-gray-500 text-center mt-1">
        Cada minuto sin RCP reduce la sobrevida un 10%
      </p>
    </div>
  </main>
</Layout>
