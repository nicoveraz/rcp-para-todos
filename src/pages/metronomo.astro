---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Metrónomo RCP">
  <main class="min-h-dvh px-5 py-6 max-w-md mx-auto flex flex-col">
    <a href="/" class="nav-back">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Volver
    </a>

    <h1 class="text-2xl font-extrabold text-andes-navy mt-2 mb-6">Metrónomo RCP</h1>

    <div class="flex-1 flex flex-col items-center justify-center gap-8">
      <!-- BPM Display -->
      <div class="text-center">
        <div id="bpm-display" class="text-7xl font-extrabold text-andes-navy tabular-nums">110</div>
        <p class="text-sm text-gray-500 mt-1">compresiones/min</p>
      </div>

      <!-- BPM Slider -->
      <div class="w-full px-4">
        <input
          type="range"
          id="bpm-slider"
          min="100"
          max="120"
          value="110"
          step="1"
          class="w-full h-2 bg-andes-sky rounded-lg appearance-none cursor-pointer
                 [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-8
                 [&::-webkit-slider-thumb]:h-8 [&::-webkit-slider-thumb]:rounded-full
                 [&::-webkit-slider-thumb]:bg-andes-red [&::-webkit-slider-thumb]:shadow-lg"
        />
        <div class="flex justify-between text-xs text-gray-400 mt-2">
          <span>100</span>
          <span class="text-andes-red font-medium">Rango ideal</span>
          <span>120</span>
        </div>
      </div>

      <!-- Visual Pulse -->
      <div class="relative">
        <button
          id="pulse-circle"
          class="w-40 h-40 rounded-full bg-andes-red flex items-center justify-center
                 text-white text-lg font-bold shadow-xl shadow-andes-red/30
                 active:scale-95 transition-all duration-100"
        >
          <span id="btn-text">INICIAR</span>
        </button>
        <div id="pulse-ring" class="absolute inset-0 rounded-full border-4 border-andes-red/30 hidden animate-pulse-ring"></div>
      </div>

      <!-- Counter -->
      <div class="text-center">
        <div class="text-4xl font-bold text-andes-navy tabular-nums" id="compression-count">0</div>
        <p class="text-sm text-gray-500">compresiones</p>
        <button id="reset-count" class="text-xs text-andes-red font-medium mt-2 underline">Reiniciar contador</button>
      </div>

      <!-- 30:2 Guide -->
      <div id="cycle-guide" class="w-full p-4 bg-andes-navy/5 rounded-2xl text-center hidden">
        <p class="text-sm font-bold text-andes-navy" id="cycle-text">Compresiones: 0 / 30</p>
        <div class="w-full bg-gray-200 rounded-full h-2 mt-2">
          <div id="cycle-bar" class="bg-andes-red h-2 rounded-full transition-all duration-150" style="width: 0%"></div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const pulseBtn = document.getElementById('pulse-circle') as HTMLButtonElement;
    const pulseRing = document.getElementById('pulse-ring')!;
    const btnText = document.getElementById('btn-text')!;
    const bpmSlider = document.getElementById('bpm-slider') as HTMLInputElement;
    const bpmDisplay = document.getElementById('bpm-display')!;
    const countDisplay = document.getElementById('compression-count')!;
    const resetBtn = document.getElementById('reset-count')!;
    const cycleGuide = document.getElementById('cycle-guide')!;
    const cycleText = document.getElementById('cycle-text')!;
    const cycleBar = document.getElementById('cycle-bar')!;

    let isPlaying = false;
    let intervalId: number | null = null;
    let audioCtx: AudioContext | null = null;
    let count = 0;
    let cycleCount = 0;

    function createClick(frequency: number, duration: number) {
      if (!audioCtx) audioCtx = new AudioContext();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.frequency.value = frequency;
      osc.type = 'sine';
      gain.gain.setValueAtTime(0.6, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
      osc.start();
      osc.stop(audioCtx.currentTime + duration);
    }

    function tick() {
      createClick(800, 0.08);
      count++;
      cycleCount++;
      countDisplay.textContent = String(count);

      // Visual pulse
      pulseBtn.style.transform = 'scale(0.9)';
      setTimeout(() => { pulseBtn.style.transform = 'scale(1)'; }, 100);

      // 30:2 cycle
      if (cycleCount <= 30) {
        cycleText.textContent = `Compresiones: ${cycleCount} / 30`;
        cycleBar.style.width = `${(cycleCount / 30) * 100}%`;
        cycleBar.classList.remove('bg-andes-sky');
        cycleBar.classList.add('bg-andes-red');
      }
      if (cycleCount === 30) {
        createClick(1200, 0.15);
        cycleText.textContent = '🌬️ ¡2 VENTILACIONES!';
        cycleBar.style.width = '100%';
        cycleBar.classList.remove('bg-andes-red');
        cycleBar.classList.add('bg-andes-sky');
        setTimeout(() => {
          cycleCount = 0;
          cycleBar.style.width = '0%';
          cycleText.textContent = 'Compresiones: 0 / 30';
        }, 4000);
      }
    }

    function start() {
      isPlaying = true;
      btnText.textContent = 'DETENER';
      pulseBtn.classList.remove('bg-andes-red');
      pulseBtn.classList.add('bg-andes-navy');
      pulseRing.classList.remove('hidden');
      cycleGuide.classList.remove('hidden');
      cycleCount = 0;

      const bpm = parseInt(bpmSlider.value);
      const ms = Math.round(60000 / bpm);
      tick();
      intervalId = window.setInterval(tick, ms);
    }

    function stop() {
      isPlaying = false;
      btnText.textContent = 'INICIAR';
      pulseBtn.classList.add('bg-andes-red');
      pulseBtn.classList.remove('bg-andes-navy');
      pulseRing.classList.add('hidden');
      if (intervalId) clearInterval(intervalId);
      intervalId = null;
    }

    pulseBtn.addEventListener('click', () => {
      if (isPlaying) stop(); else start();
    });

    bpmSlider.addEventListener('input', () => {
      bpmDisplay.textContent = bpmSlider.value;
      if (isPlaying) {
        stop();
        start();
      }
    });

    resetBtn.addEventListener('click', () => {
      count = 0;
      cycleCount = 0;
      countDisplay.textContent = '0';
      cycleText.textContent = 'Compresiones: 0 / 30';
      cycleBar.style.width = '0%';
    });
  </script>
</Layout>
