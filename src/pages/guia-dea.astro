---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const iconosDea = [
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-600"><path d="M16 7V3H8v4H2v13h20V7h-6zm-6-2h4v2h-4V5zM9 17v-1H7v-2h2v-1h2v1h2v2h-2v1H9z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-600"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-600"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-600"><path d="M19.5 3.5L18 2l-1.5 1.5L15 2l-1.5 1.5L12 2l-1.5 1.5L9 2 7.5 3.5 6 2 4.5 3.5 3 2v20l1.5-1.5L6 22l1.5-1.5L9 22l1.5-1.5L12 22l1.5-1.5L15 22l1.5-1.5L18 22l1.5-1.5L21 22V2l-1.5 1.5zM19 19.09H5V4.91h14v14.18zM6 15h12v2H6zm0-4h12v2H6zm0-4h12v2H6z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-600"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-600"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg>',
];

const pasos = [
  {
    titulo: 'Encender el DEA',
    descripcion: 'Presiona el botón de encendido. El equipo comenzará a dar instrucciones de voz.',
    tip: 'Los DEA modernos se activan al abrir la tapa. Escucha atentamente las instrucciones.',
  },
  {
    titulo: 'Preparar al paciente',
    descripcion: 'Descubre el pecho del paciente. Si está mojado, seca la zona. Retira parches médicos si los tiene.',
    tip: 'Si tiene mucho vello, afeita la zona donde irán los parches para mejor adherencia.',
  },
  {
    titulo: 'Colocar los parches',
    descripcion: 'Coloca un parche bajo la clavícula derecha y otro bajo la axila izquierda. Sigue el diagrama del parche.',
    tip: 'Los parches tienen un diagrama impreso. Asegúrate de que estén bien adheridos sin arrugas ni burbujas.',
  },
  {
    titulo: 'Análisis del ritmo',
    descripcion: 'El DEA analizará el ritmo cardíaco. NO toques al paciente durante el análisis.',
    tip: '¡Todos atrás! Cualquier movimiento puede interferir con el análisis. Avisa a todos que se alejen.',
  },
  {
    titulo: 'Descarga (si indicada)',
    descripcion: 'Si el DEA indica descarga: asegúrate de que nadie toque al paciente y presiona el botón de descarga.',
    tip: 'Grita "¡TODOS ATRÁS!" antes de presionar. El DEA solo recomienda descarga si detecta un ritmo desfibrilable.',
  },
  {
    titulo: 'Reiniciar compresiones',
    descripcion: 'Inmediatamente después de la descarga (o si no se indica), reinicia compresiones torácicas a una frecuencia de 110 por minuto.',
    tip: 'El DEA re-analizará automáticamente cada 2 minutos. No retires los parches. No detengas las compresiones hasta que el DEA lo indique.',
  },
];
---

<Layout title="Guía Uso DEA">
  <main class="min-h-dvh px-5 py-6 max-w-md mx-auto">
    <a href={base} class="nav-back">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Volver
    </a>

    <h1 class="text-2xl font-extrabold text-andes-navy mt-2 mb-2">Guía Uso DEA</h1>
    <p class="text-sm text-gray-500 mb-6">Desfibrilador Externo Automático — Adultos</p>

    <!-- Important callout -->
    <div class="p-4 bg-amber-50 border border-amber-200 rounded-2xl mb-6">
      <p class="text-sm text-amber-800 font-medium">
        ⚡ El DEA es seguro para cualquier persona. Te guía con voz paso a paso. No puedes hacer daño con él.
      </p>
    </div>

    <div class="space-y-4">
      {pasos.map((paso, i) => (
        <details class="card group">
          <summary class="flex items-start gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <div class="step-number bg-amber-500">{i + 1}</div>
            <div class="flex-1">
              <h2 class="font-bold text-andes-navy">{paso.titulo}</h2>
              <p class="text-sm text-gray-600 mt-1">{paso.descripcion}</p>
            </div>
            <span class="mt-1" set:html={iconosDea[i]} />
          </summary>
          <div class="mt-4 pt-4 border-t border-gray-100 ml-14">
            <p class="text-sm text-gray-700 leading-relaxed"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-amber-500 inline-block mr-1 -mt-0.5"><path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/></svg> <strong>Tip:</strong> {paso.tip}</p>
          </div>
        </details>
      ))}
    </div>

    <!-- Compressions section -->
    <div class="mt-8">
      <h2 class="text-lg font-extrabold text-andes-navy mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-andes-red"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        ¿Cómo deben ser las compresiones?
      </h2>
      <div class="space-y-3">
        <div class="card flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <div>
            <p class="font-semibold text-andes-navy text-sm">Frecuencia: 100–120 por minuto</p>
            <p class="text-xs text-gray-500 mt-0.5">Ideal: 110/min. Usa el metrónomo para mantener el ritmo.</p>
          </div>
        </div>
        <div class="card flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <div>
            <p class="font-semibold text-andes-navy text-sm">Profundidad: 5 a 6 cm</p>
            <p class="text-xs text-gray-500 mt-0.5">Comprime fuerte. Es mejor comprimir de más que de menos.</p>
          </div>
        </div>
        <div class="card flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <div>
            <p class="font-semibold text-andes-navy text-sm">Ubicación: centro del pecho</p>
            <p class="text-xs text-gray-500 mt-0.5">Talón de la mano en la mitad inferior del esternón, manos entrelazadas, brazos rectos.</p>
          </div>
        </div>
        <div class="card flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <div>
            <p class="font-semibold text-andes-navy text-sm">Re-expansión completa</p>
            <p class="text-xs text-gray-500 mt-0.5">Permite que el pecho vuelva a su posición original entre cada compresión. No te apoyes sobre el paciente.</p>
          </div>
        </div>
        <div class="card flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-andes-red flex-shrink-0 mt-0.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <div>
            <p class="font-semibold text-andes-navy text-sm">Minimiza interrupciones</p>
            <p class="text-xs text-gray-500 mt-0.5">No detengas las compresiones más de 10 segundos. Rota con otro rescatista cada 2 minutos si es posible.</p>
          </div>
        </div>
      </div>
      <a href={`${base}metronomo`} class="btn-secondary flex items-center justify-center gap-2 mt-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Abrir Metrónomo (110/min)
      </a>
    </div>

    <!-- FAQ -->
    <div class="mt-8">
      <h2 class="text-lg font-extrabold text-andes-navy mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-andes-navy"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>
        Preguntas frecuentes
      </h2>
      <div class="space-y-3">
        <details class="card group">
          <summary class="flex items-start gap-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <span class="font-bold text-andes-navy text-sm flex-1">¿Debo dar ventilaciones (respiración boca a boca)?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="mt-3 pt-3 border-t border-gray-100">
            <p class="text-sm text-gray-700 leading-relaxed">
              <strong>Si no estás capacitado en ventilaciones, realiza solo compresiones.</strong> Las compresiones continuas sin ventilaciones son efectivas y recomendadas para reanimadores no profesionales de salud (guías AHA 2025).
            </p>
            <p class="text-sm text-gray-700 leading-relaxed mt-2">
              Lo más importante es no dejar de comprimir. Las compresiones mantienen la circulación de sangre oxigenada al cerebro y los órganos vitales.
            </p>
          </div>
        </details>
        <details class="card group">
          <summary class="flex items-start gap-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <span class="font-bold text-andes-navy text-sm flex-1">¿Puedo hacer daño con el DEA?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="mt-3 pt-3 border-t border-gray-100">
            <p class="text-sm text-gray-700 leading-relaxed">
              <strong>No.</strong> El DEA analiza el ritmo cardíaco y solo permite la descarga si detecta un ritmo que lo requiere. Si el ritmo no es desfibrilable, el botón no tendrá efecto. Es un equipo diseñado para ser usado por cualquier persona.
            </p>
          </div>
        </details>
        <details class="card group">
          <summary class="flex items-start gap-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <span class="font-bold text-andes-navy text-sm flex-1">¿Cuándo dejo de hacer compresiones?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="mt-3 pt-3 border-t border-gray-100">
            <p class="text-sm text-gray-700 leading-relaxed">
              Detén las compresiones solo cuando: la persona comience a respirar normalmente, llegue el equipo de emergencia y te releve, el DEA indique que analiza el ritmo, o estés físicamente agotado y no puedas continuar.
            </p>
          </div>
        </details>
      </div>
    </div>

    <div class="mt-8">
      <a href={`${base}simulador-dea`} class="btn-primary flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Practicar con Simulador DEA
      </a>
    </div>
  </main>
</Layout>
