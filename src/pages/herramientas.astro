---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Herramientas de Práctica">
  <main class="min-h-dvh px-5 py-6 max-w-md mx-auto flex flex-col">
    <a href={base} class="nav-back">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Volver
    </a>

    <h1 class="text-2xl font-extrabold text-andes-navy mt-2 mb-4">Herramientas de Práctica</h1>

    <!-- Tabs -->
    <div class="flex bg-gray-100 rounded-xl p-1 mb-6">
      <button id="tab-metronomo" class="flex-1 py-2.5 text-sm font-bold rounded-lg bg-white text-andes-navy shadow-sm transition-all">
        Metrónomo
      </button>
      <button id="tab-timer" class="flex-1 py-2.5 text-sm font-bold rounded-lg text-gray-500 transition-all">
        Timer
      </button>
    </div>

    <!-- ===== METRÓNOMO ===== -->
    <div id="panel-metronomo" class="flex-1 flex flex-col items-center justify-center gap-8">
      <div class="text-center">
        <div id="bpm-display" class="text-7xl font-extrabold text-andes-navy tabular-nums">110</div>
        <p class="text-sm text-gray-500 mt-1">compresiones/min</p>
      </div>

      <div class="w-full px-4">
        <input
          type="range"
          id="bpm-slider"
          min="100"
          max="120"
          value="110"
          step="1"
          class="w-full h-2 bg-andes-sky rounded-lg appearance-none cursor-pointer
                 [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-8
                 [&::-webkit-slider-thumb]:h-8 [&::-webkit-slider-thumb]:rounded-full
                 [&::-webkit-slider-thumb]:bg-andes-red [&::-webkit-slider-thumb]:shadow-lg"
        />
        <div class="flex justify-between text-xs text-gray-400 mt-2">
          <span>100</span>
          <span class="text-andes-red font-medium">Rango ideal</span>
          <span>120</span>
        </div>
      </div>

      <div class="relative">
        <button
          id="pulse-circle"
          class="w-40 h-40 rounded-full bg-andes-red flex items-center justify-center
                 text-white text-lg font-bold shadow-xl shadow-andes-red/30
                 active:scale-95 transition-all duration-100"
        >
          <span id="metro-btn-text">INICIAR</span>
        </button>
        <div id="pulse-ring" class="absolute inset-0 rounded-full border-4 border-andes-red/30 hidden animate-pulse-ring"></div>
      </div>

      <div class="text-center">
        <div class="text-4xl font-bold text-andes-navy tabular-nums" id="compression-count">0</div>
        <p class="text-sm text-gray-500">compresiones</p>
        <button id="reset-count" class="text-xs text-andes-red font-medium mt-2 underline">Reiniciar contador</button>
      </div>

      <div id="cycle-guide" class="w-full p-4 bg-andes-navy/5 rounded-2xl text-center hidden">
        <p class="text-sm font-bold text-andes-navy" id="cycle-text">Compresiones: 0 / 30</p>
        <div class="w-full bg-gray-200 rounded-full h-2 mt-2">
          <div id="cycle-bar" class="bg-andes-red h-2 rounded-full transition-all duration-150" style="width: 0%"></div>
        </div>
      </div>
    </div>

    <!-- ===== TIMER ===== -->
    <div id="panel-timer" class="flex-1 flex-col items-center justify-center gap-8 hidden">
      <div class="flex flex-col items-center gap-8 w-full">
        <div class="relative">
          <svg class="w-64 h-64" viewBox="0 0 200 200">
            <circle cx="100" cy="100" r="90" fill="none" stroke="#E5E7EB" stroke-width="6"/>
            <circle
              id="timer-ring"
              cx="100" cy="100" r="90"
              fill="none"
              stroke="#1B3A5C"
              stroke-width="6"
              stroke-linecap="round"
              stroke-dasharray="565.49"
              stroke-dashoffset="0"
              transform="rotate(-90 100 100)"
              class="transition-all duration-1000"
            />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <div id="timer-display" class="text-5xl font-extrabold text-andes-navy tabular-nums">2:00</div>
            <p id="timer-label" class="text-sm text-gray-500 mt-1">Listo para iniciar</p>
          </div>
        </div>

        <div class="flex gap-3 w-full">
          <button data-duration="60" class="duration-btn flex-1 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl text-sm">1 min</button>
          <button data-duration="120" class="duration-btn flex-1 py-3 bg-andes-navy text-white font-semibold rounded-xl text-sm">2 min</button>
          <button data-duration="180" class="duration-btn flex-1 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl text-sm">3 min</button>
          <button data-duration="300" class="duration-btn flex-1 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl text-sm">5 min</button>
        </div>

        <label class="flex items-center justify-between w-full px-1">
          <span class="text-sm font-medium text-andes-navy">Pausa 10s entre ciclos</span>
          <input type="checkbox" id="pause-toggle" checked
            class="w-11 h-6 appearance-none bg-gray-300 rounded-full relative cursor-pointer
                   checked:bg-andes-red transition-colors
                   after:content-[''] after:absolute after:top-0.5 after:left-0.5
                   after:w-5 after:h-5 after:bg-white after:rounded-full after:transition-transform
                   checked:after:translate-x-5" />
        </label>

        <div class="flex gap-4 w-full">
          <button
            id="btn-start"
            class="flex-1 py-4 bg-andes-red text-white font-bold rounded-2xl text-lg
                   shadow-lg shadow-andes-red/25 active:scale-95 transition-transform"
          >INICIAR</button>
          <button
            id="btn-stop"
            class="w-16 py-4 bg-gray-200 text-gray-600 font-bold rounded-2xl text-lg
                   active:scale-95 transition-transform"
          >↺</button>
        </div>

        <div class="w-full p-4 bg-gray-50 rounded-2xl">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-gray-500 font-medium">RONDAS COMPLETADAS</p>
              <p id="round-count" class="text-3xl font-extrabold text-andes-navy">0</p>
            </div>
            <div>
              <p class="text-xs text-gray-500 font-medium">TIEMPO TOTAL</p>
              <p id="total-time" class="text-3xl font-extrabold text-andes-navy">0:00</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    // ===== TABS =====
    const tabMetro = document.getElementById('tab-metronomo')!;
    const tabTimer = document.getElementById('tab-timer')!;
    const panelMetro = document.getElementById('panel-metronomo')!;
    const panelTimer = document.getElementById('panel-timer')!;

    function showTab(tab: 'metronomo' | 'timer') {
      const activeClass = 'bg-white text-andes-navy shadow-sm';
      const inactiveClass = 'text-gray-500';

      if (tab === 'metronomo') {
        panelMetro.classList.remove('hidden');
        panelMetro.classList.add('flex');
        panelTimer.classList.add('hidden');
        panelTimer.classList.remove('flex');
        tabMetro.className = `flex-1 py-2.5 text-sm font-bold rounded-lg ${activeClass} transition-all`;
        tabTimer.className = `flex-1 py-2.5 text-sm font-bold rounded-lg ${inactiveClass} transition-all`;
        stopTimer();
      } else {
        panelTimer.classList.remove('hidden');
        panelTimer.classList.add('flex');
        panelMetro.classList.add('hidden');
        panelMetro.classList.remove('flex');
        tabTimer.className = `flex-1 py-2.5 text-sm font-bold rounded-lg ${activeClass} transition-all`;
        tabMetro.className = `flex-1 py-2.5 text-sm font-bold rounded-lg ${inactiveClass} transition-all`;
        stopMetronome();
      }
    }

    tabMetro.addEventListener('click', () => showTab('metronomo'));
    tabTimer.addEventListener('click', () => showTab('timer'));

    // Check hash for direct tab linking
    if (window.location.hash === '#timer') showTab('timer');

    // ===== METRÓNOMO =====
    const pulseBtn = document.getElementById('pulse-circle') as HTMLButtonElement;
    const pulseRing = document.getElementById('pulse-ring')!;
    const metroBtnText = document.getElementById('metro-btn-text')!;
    const bpmSlider = document.getElementById('bpm-slider') as HTMLInputElement;
    const bpmDisplay = document.getElementById('bpm-display')!;
    const countDisplay = document.getElementById('compression-count')!;
    const resetBtn = document.getElementById('reset-count')!;
    const cycleGuide = document.getElementById('cycle-guide')!;
    const cycleText = document.getElementById('cycle-text')!;
    const cycleBar = document.getElementById('cycle-bar')!;

    let metroPlaying = false;
    let metroInterval: number | null = null;
    let audioCtx: AudioContext | null = null;
    let metroCount = 0;
    let cycleCount = 0;

    function createClick(frequency: number, dur: number) {
      if (!audioCtx) audioCtx = new AudioContext();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.frequency.value = frequency;
      osc.type = 'sine';
      gain.gain.setValueAtTime(0.6, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + dur);
      osc.start();
      osc.stop(audioCtx.currentTime + dur);
    }

    function metroTick() {
      createClick(800, 0.08);
      metroCount++;
      cycleCount++;
      countDisplay.textContent = String(metroCount);
      pulseBtn.style.transform = 'scale(0.9)';
      setTimeout(() => { pulseBtn.style.transform = 'scale(1)'; }, 100);

      if (cycleCount <= 30) {
        cycleText.textContent = `Compresiones: ${cycleCount} / 30`;
        cycleBar.style.width = `${(cycleCount / 30) * 100}%`;
        cycleBar.classList.remove('bg-andes-sky');
        cycleBar.classList.add('bg-andes-red');
      }
      if (cycleCount === 30) {
        createClick(1200, 0.15);
        cycleText.textContent = '🌬️ ¡2 VENTILACIONES!';
        cycleBar.style.width = '100%';
        cycleBar.classList.remove('bg-andes-red');
        cycleBar.classList.add('bg-andes-sky');
        setTimeout(() => {
          cycleCount = 0;
          cycleBar.style.width = '0%';
          cycleText.textContent = 'Compresiones: 0 / 30';
        }, 4000);
      }
    }

    function startMetronome() {
      metroPlaying = true;
      metroBtnText.textContent = 'DETENER';
      pulseBtn.classList.remove('bg-andes-red');
      pulseBtn.classList.add('bg-andes-navy');
      pulseRing.classList.remove('hidden');
      cycleGuide.classList.remove('hidden');
      cycleCount = 0;
      const bpm = parseInt(bpmSlider.value);
      const ms = Math.round(60000 / bpm);
      metroTick();
      metroInterval = window.setInterval(metroTick, ms);
    }

    function stopMetronome() {
      metroPlaying = false;
      metroBtnText.textContent = 'INICIAR';
      pulseBtn.classList.add('bg-andes-red');
      pulseBtn.classList.remove('bg-andes-navy');
      pulseRing.classList.add('hidden');
      if (metroInterval) clearInterval(metroInterval);
      metroInterval = null;
    }

    pulseBtn.addEventListener('click', () => {
      if (metroPlaying) stopMetronome(); else startMetronome();
    });

    bpmSlider.addEventListener('input', () => {
      bpmDisplay.textContent = bpmSlider.value;
      if (metroPlaying) { stopMetronome(); startMetronome(); }
    });

    resetBtn.addEventListener('click', () => {
      metroCount = 0;
      cycleCount = 0;
      countDisplay.textContent = '0';
      cycleText.textContent = 'Compresiones: 0 / 30';
      cycleBar.style.width = '0%';
    });

    // ===== TIMER =====
    const timerDisplay = document.getElementById('timer-display')!;
    const timerLabel = document.getElementById('timer-label')!;
    const timerRing = document.getElementById('timer-ring')!;
    const btnStart = document.getElementById('btn-start') as HTMLButtonElement;
    const btnStop = document.getElementById('btn-stop') as HTMLButtonElement;
    const roundCount = document.getElementById('round-count')!;
    const totalTime = document.getElementById('total-time')!;
    const durationBtns = document.querySelectorAll('.duration-btn');
    const pauseToggle = document.getElementById('pause-toggle') as HTMLInputElement;

    let duration = 120;
    let remaining = 120;
    let timerRunning = false;
    let isPausing = false;
    let pauseRemaining = 10;
    let timerInterval: number | null = null;
    let rounds = 0;
    let totalSeconds = 0;
    let totalIntervalId: number | null = null;
    const circumference = 2 * Math.PI * 90;

    function formatTime(s: number): string {
      const m = Math.floor(s / 60);
      const sec = s % 60;
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function beep(freq: number, dur: number) {
      if (!audioCtx) audioCtx = new AudioContext();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.5, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + dur);
      osc.start();
      osc.stop(audioCtx.currentTime + dur);
    }

    function updateTimerDisplay() {
      timerDisplay.textContent = formatTime(remaining);
      const progress = 1 - remaining / duration;
      timerRing.setAttribute('stroke-dashoffset', String(circumference * (1 - progress)));

      if (remaining <= 10 && remaining > 0 && timerRunning) {
        timerRing.setAttribute('stroke', '#E63946');
        timerDisplay.classList.add('text-andes-red');
        timerDisplay.classList.remove('text-andes-navy');
      } else {
        timerRing.setAttribute('stroke', '#1B3A5C');
        timerDisplay.classList.remove('text-andes-red');
        timerDisplay.classList.add('text-andes-navy');
      }
    }

    function timerTick() {
      remaining--;
      updateTimerDisplay();
      if (remaining <= 5 && remaining > 0) beep(800, 0.1);
      if (remaining <= 0) {
        beep(1200, 0.5);
        setTimeout(() => beep(1200, 0.5), 600);
        setTimeout(() => beep(1200, 0.5), 1200);
        rounds++;
        roundCount.textContent = String(rounds);
        if (navigator.vibrate) navigator.vibrate([200, 100, 200, 100, 200]);
        if (timerInterval) clearInterval(timerInterval);
        timerInterval = null;
        if (pauseToggle.checked) {
          startPause();
        } else {
          remaining = duration;
          timerLabel.textContent = `¡Ronda ${rounds} completada!`;
          updateTimerDisplay();
          timerInterval = window.setInterval(timerTick, 1000);
        }
      }
    }

    function startPause() {
      isPausing = true;
      pauseRemaining = 10;
      timerLabel.textContent = `Ronda ${rounds} completada — Pausa`;
      timerDisplay.textContent = String(pauseRemaining);
      timerRing.setAttribute('stroke', '#A8DADC');
      timerRing.setAttribute('stroke-dashoffset', '0');
      btnStart.textContent = 'SALTAR';
      timerInterval = window.setInterval(() => {
        pauseRemaining--;
        timerDisplay.textContent = String(pauseRemaining);
        timerRing.setAttribute('stroke-dashoffset', String(circumference * (1 - pauseRemaining / 10)));
        if (pauseRemaining <= 3 && pauseRemaining > 0) beep(600, 0.1);
        if (pauseRemaining <= 0) endPause();
      }, 1000);
    }

    function endPause() {
      isPausing = false;
      if (timerInterval) clearInterval(timerInterval);
      remaining = duration;
      updateTimerDisplay();
      timerLabel.textContent = 'Compresiones en curso...';
      btnStart.textContent = 'PAUSA';
      beep(1000, 0.2);
      timerInterval = window.setInterval(timerTick, 1000);
    }

    function startTimer() {
      if (isPausing) { endPause(); return; }
      if (timerRunning) {
        timerRunning = false;
        if (timerInterval) clearInterval(timerInterval);
        if (totalIntervalId) clearInterval(totalIntervalId);
        btnStart.textContent = 'CONTINUAR';
        timerLabel.textContent = 'Pausado';
        return;
      }
      timerRunning = true;
      btnStart.textContent = 'PAUSA';
      timerLabel.textContent = 'Compresiones en curso...';
      timerInterval = window.setInterval(timerTick, 1000);
      totalIntervalId = window.setInterval(() => {
        totalSeconds++;
        totalTime.textContent = formatTime(totalSeconds);
      }, 1000);
    }

    function stopTimer() {
      timerRunning = false;
      isPausing = false;
      if (timerInterval) clearInterval(timerInterval);
      if (totalIntervalId) clearInterval(totalIntervalId);
      timerInterval = null;
      totalIntervalId = null;
      btnStart.textContent = 'INICIAR';
      remaining = duration;
      updateTimerDisplay();
    }

    btnStart.addEventListener('click', startTimer);

    btnStop.addEventListener('click', () => {
      stopTimer();
      rounds = 0;
      totalSeconds = 0;
      roundCount.textContent = '0';
      totalTime.textContent = '0:00';
      timerLabel.textContent = 'Listo para iniciar';
    });

    durationBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const dur = parseInt((btn as HTMLButtonElement).dataset.duration || '120');
        duration = dur;
        remaining = dur;
        durationBtns.forEach(b => {
          (b as HTMLElement).className = 'duration-btn flex-1 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl text-sm';
        });
        (btn as HTMLElement).className = 'duration-btn flex-1 py-3 bg-andes-navy text-white font-semibold rounded-xl text-sm';
        if (timerRunning) stopTimer();
        updateTimerDisplay();
        timerLabel.textContent = 'Listo para iniciar';
      });
    });

    updateTimerDisplay();
  </script>
</Layout>
